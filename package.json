  "main": "index.js",
  "scripts": {
    "start": "node server.ts",
    "dev": "nodemon server.ts",
    "build": "cd front && npm install && npm run build && rm -rf ../public && cp -r dist ../public",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:migrate": "npx knex migrate:latest",
    "db:migrate-make": "npx knex migrate:make --knexfile ./knexfile.js",
    "db:seed": "npx knex seed:run --knexfile ./knexfile.js",
    "db:seed-make": "npx knex seed:make --knexfile ./knexfile.js",
    "migrate-latest": "npx knex migrate:latest --knexfile ./knexfile.js",
    "migrate-down": "npx knex migrate:down --knexfile /knexfile.js",
    "seed-data": "npx knex seed:run --knexfile ./knexfile.js",
    "db:reset": "knex migrate:rollback --all && knex migrate:latest && knex seed:run"
  },
