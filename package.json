{
  "name": "btc-fullstack",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "ts-node server.ts",
    "dev": "nodemon server.ts",
    "build": "cd front && npm install && npm run build && rm -rf ../public && cp -r dist ../public",
    "test": "mocha --require ts-node/register --global-teardown test/setup.ts 'test/**/*.test.ts' --exit",
    "test:doubles": "TS_NODE_PROJECT=tsconfig.test.json mocha --require ts-node/register --global-teardown test/setup.ts test-double/**/*.double.test.ts",
    "db:migrate": "npx knex migrate:latest",
    "db:migrate-make": "npx knex migrate:make --knexfile ./knexfile.ts",
    "db:seed": "npx knex seed:run --knexfile ./knexfile.ts",
    "db:seed-make": "npx knex seed:make --knexfile ./knexfile.ts",
    "migrate-latest": "npx knex migrate:latest --knexfile ./knexfile.ts",
    "migrate-down": "npx knex migrate:down --knexfile /knexfile.ts",
    "seed-data": "npx knex seed:run --knexfile ./knexfile.ts",
    "db:reset": "knex migrate:rollback --all && npx knex migrate:latest && npx knex seed:run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.16.1",
    "cors": "^2.8.6",
    "csvtojson": "^2.0.14",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "knex": "^3.2.10",
    "pg": "^8.21.0",
    "react-redux": "^9.3.0",
    "recharts": "^3.8.1",
    "ts-node": "^10.9.2",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/knex": "^0.15.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@types/sinon": "^21.0.1",
    "@types/sinon-chai": "^4.0.0",
    "chai": "^4.5.0",
    "chai-as-promised": "^8.0.2",
    "mocha": "^11.7.6",
    "nodemon": "^3.1.14",
    "sinon": "^22.0.0",
    "sinon-chai": "^3.7.0",
    "typescript": "^6.0.3"
  }
}
